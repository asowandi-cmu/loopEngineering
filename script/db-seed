#!/bin/bash
# script/db-seed - Seed database with development data
#
# Creates example trades in the database for development/testing.
# Safe to run multiple times - skips seeding if trades already exist.

set -e

cd "$(dirname "$0")/.."

# Load environment
if [ -f .env ]; then
    export $(grep -v '^#' .env | xargs)
fi

export FLASK_APP=src/app:create_app

echo "==> Seeding database..."

PYTHONPATH=src python << 'EOF'
from datetime import datetime

from app import create_app
from app.controllers.trade import create_trade, list_trades
from app.schemas.trade import TradeCreate

# Representative sample trades (a winner, a loser, and a short) so the journal
# and stats header have data to render in development.
SAMPLES = [
    {
        "symbol": "ES", "product_name": "E-mini S&P 500", "side": "long",
        "contracts": 2, "entry_price": "5000.00", "exit_price": "5010.00",
        "tick_size": "0.25", "tick_value": "12.50",
        "entry_at": datetime(2026, 7, 19, 13, 30),
        "exit_at": datetime(2026, 7, 19, 14, 5),
        "fees": "4.50", "strategy": "ORB", "notes": "clean breakout",
    },
    {
        "symbol": "NQ", "product_name": "E-mini Nasdaq-100", "side": "short",
        "contracts": 1, "entry_price": "18000.00", "exit_price": "17990.00",
        "tick_size": "0.25", "tick_value": "5.00",
        "entry_at": datetime(2026, 7, 19, 15, 0),
        "exit_at": datetime(2026, 7, 19, 15, 20),
        "fees": "2.10", "strategy": "fade", "notes": "",
    },
    {
        "symbol": "CL", "product_name": "Crude Oil", "side": "long",
        "contracts": 1, "entry_price": "75.00", "exit_price": "74.90",
        "tick_size": "0.01", "tick_value": "10.00",
        "entry_at": datetime(2026, 7, 18, 10, 0),
        "exit_at": datetime(2026, 7, 18, 10, 45),
        "fees": "2.10", "strategy": "trend", "notes": "stopped out",
    },
]

app = create_app()
with app.app_context():
    if list_trades():
        print("Database already has trades, skipping seed")
    else:
        for sample in SAMPLES:
            create_trade(TradeCreate.model_validate(sample))
        print(f"Added {len(SAMPLES)} sample trades")
EOF

echo "==> Database seeded!"
